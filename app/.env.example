# Supabase (https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (https://platform.openai.com → API Keys)
OPENAI_API_KEY=sk-your-openai-key

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Logging (optional — default: debug in dev, info in production)
# LOG_LEVEL=debug
# NEXT_PUBLIC_LOG_LEVEL=debug

# Widget Download URL (GitHub Releases asset URL)
NEXT_PUBLIC_WIDGET_DOWNLOAD_URL=https://github.com/your-org/stride/releases/latest/download/Stride-Widget.dmg
